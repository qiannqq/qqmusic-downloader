# QQ音乐 Cookie 配置（逐字段方式）
# 在腾讯云 Pages 控制台的环境变量中逐个添加以下变量
# 无需 base64 编码，直接填入原始值即可

# ============================================
# 核心字段（必需）
# ============================================

# QQ号（QQ登录时使用）
QM_UIN=

# QQ unionid（QQ登录标识）
# 格式: 32位十六进制字符串
QM_QQUNIONID=

# 登录类型
# 1 = 微信登录, 2 = QQ登录
QM_TMELOGINTYPE=2

# QQ音乐核心认证密钥
# 这是最重要的字段，用于获取播放链接
QM_QQMUSIC_KEY=

# ============================================
# Token 字段（可选，用于自动刷新）
# ============================================

# QQ访问令牌
QM_ACCESS_TOKEN=

# QQ OpenID
QM_OPENID=

# QQ刷新令牌
QM_REFRESH_TOKEN=

# 令牌过期时间戳（Unix时间戳）
QM_EXPIRES_AT=

# ============================================
# 辅助字段（可选）
# ============================================

# 加密uin
# QM_EUIN=oKvloevkNevF7v**

# musickey创建时间戳
# QM_MUSICKEY_CREATETIME=1778534709

# ============================================
# 向后兼容（旧格式，不建议使用）
# 如果配置了 QM_COOKIES，将优先使用它
# ============================================
# QM_COOKIES=uin=xxx;qqmusic_key=xxx;...
